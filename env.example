NODE_ENV=production

# Backend
SESSION_SECRET=

# Cloudinary (lấy ở dashboard cloudinary.com)
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-api-key
CLOUD_API_SECRET=your-api-secret

# Frontend (NEXT_PUBLIC_* — nhúng vào bundle lúc build)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase web config (lấy ở Firebase Console > Project settings > Your apps)
NEXT_PUBLIC_API_KEY=your-firebase-api-key
NEXT_PUBLIC_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_PROJECT_ID=your-project-id
NEXT_PUBLIC_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_APP_ID=1:000000000000:web:xxxxxxxxxxxx
NEXT_PUBLIC_MEASUREMENT_ID=G-XXXXXXXXXX
